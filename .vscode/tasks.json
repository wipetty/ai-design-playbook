{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check if node_modules exists and install",
      "type": "shell",
      "command": "[ -s \"$HOME/.nvm/nvm.sh\" ] && . \"$HOME/.nvm/nvm.sh\"; if [ ! -d \"node_modules\" ]; then pnpm install; fi",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Terminal with pnpm dev",
      "type": "shell",
      "command": "[ -s \"$HOME/.nvm/nvm.sh\" ] && . \"$HOME/.nvm/nvm.sh\"; pnpm dev",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "dependsOn": ["Check if node_modules exists and install"]
    },
    {
      "type": "shell",
      "command": "[ -s \"$HOME/.nvm/nvm.sh\" ] && . \"$HOME/.nvm/nvm.sh\"; pnpm install",
      "problemMatcher": [],
      "label": "install",
      "detail": "install dependencies from package",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "type": "shell",
      "command": "[ -s \"$HOME/.nvm/nvm.sh\" ] && . \"$HOME/.nvm/nvm.sh\"; pnpm dev",
      "problemMatcher": [],
      "label": "run",
      "detail": "run the application",
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
